{
    "all_features": {
        "image": "ubuntu:latest",
        "overrideFeatureInstallOrder": [
            "./node",
            "./npm-packages",
            "./os-packages",
            "./cli-tools",
            "./codex",
            "./pi",
            "./playwright",
            "./python",
            "./user"
        ],
        "features": {
            "node": {
                "version": "lts"
            },
            "npm-packages": {
                "npmGlobalPackages": "markdownlint-cli2"
            },
            "os-packages": {
                "packages": "tree"
            },
            "cli-tools": {
                "installBrave": true,
                "installContext7": true,
                "installFirecrawl": true,
                "installTavily": true
            },
            "codex": {
                "version": "latest"
            },
            "pi": {
                "version": "latest"
            },
            "playwright": {
                "browser": "chromium",
                "installSystemDeps": true
            },
            "python": {
                "version": "3.14",
                "installPipx": true,
                "installVenv": true,
                "installRuff": true,
                "installPyright": true
            },
            "user": {
                "username": "dev",
                "uid": "1000",
                "gid": "1000"
            }
        }
    }
}
