{
    "all_features": {
        "image": "ubuntu:latest",
        "overrideFeatureInstallOrder": [
            "./apt-python",
            "./node",
            "./npm-packages",
            "./apt-packages",
            "./cli-tools",
            "./codex",
            "./pi",
            "./playwright",
            "./pipx-packages",
            "./user"
        ],
        "features": {
            "apt-python": {
                "version": "3.14",
                "installPip": true,
                "installPipx": true,
                "installVenv": true
            },
            "node": {
                "version": "lts"
            },
            "npm-packages": {
                "npmPackages": "markdownlint-cli2"
            },
            "apt-packages": {
                "aptPackages": "tree"
            },
            "cli-tools": {
                "installBrave": true,
                "installContext7": true,
                "installFirecrawl": true,
                "installTavily": true
            },
            "codex": {
                "version": "latest"
            },
            "pi": {
                "version": "latest"
            },
            "playwright": {
                "browser": "chromium"
            },
            "pipx-packages": {
                "pipxPackages": "black"
            },
            "user": {
                "username": "dev",
                "uid": "1000",
                "gid": "1000"
            }
        }
    }
}
