{
    "context7": {
        "image": "ubuntu:latest",
        "overrideFeatureInstallOrder": [
            "./node",
            "./search-cli-tools"
        ],
        "features": {
            "node": {
                "version": "lts"
            },
            "search-cli-tools": {
                "installBrave": false,
                "installContext7": true,
                "installFirecrawl": false,
                "installTavily": false
            }
        }
    },
    "all-tools": {
        "image": "ubuntu:latest",
        "overrideFeatureInstallOrder": [
            "./apt-python",
            "./node",
            "./search-cli-tools"
        ],
        "features": {
            "apt-python": {
                "version": "3.14",
                "installPip": true,
                "installPipx": true,
                "installVenv": true
            },
            "node": {
                "version": "lts"
            },
            "search-cli-tools": {
                "installBrave": true,
                "installContext7": true,
                "installFirecrawl": true,
                "installTavily": true
            }
        }
    }
}
