{
    "name": "Python",
    "id": "python",
    "version": "1.0.0",
    "description": "Install Python, pip, pipx, and optional development tools.",
    "options": {
        "version": {
            "type": "string",
            "enum": [
                "3.11",
                "3.12",
                "3.13",
                "3.14"
            ],
            "default": "3.14",
            "description": "Python version to install."
        },
        "installPipx": {
            "type": "boolean",
            "default": true,
            "description": "Install pipx."
        },
        "installVenv": {
            "type": "boolean",
            "default": true,
            "description": "Ensure venv support is available."
        },
        "installRuff": {
            "type": "boolean",
            "default": true,
            "description": "Install ruff via pipx."
        },
        "installPyright": {
            "type": "boolean",
            "default": false,
            "description": "Install pyright via npm; requires Node.js and npm."
        },
        "minReleaseAge": {
            "type": "string",
            "default": "7",
            "description": "Minimum release age in days for npm and PyPI installation."
        }
    }
}
