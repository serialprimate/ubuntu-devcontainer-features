{
    "name": "Playwright",
    "id": "playwright",
    "version": "1.0.0",
    "description": "Install the Playwright runtime and optional browser dependencies.",
    "containerEnv": {
        "PLAYWRIGHT_BROWSERS_PATH": "/ms-playwright"
    },
    "options": {
        "version": {
            "type": "string",
            "default": "1.61.0",
            "description": "Version of the Playwright package to install."
        },
        "browser": {
            "type": "string",
            "enum": [
                "chromium",
                "firefox",
                "webkit"
            ],
            "default": "chromium",
            "description": "Browser to install for Playwright."
        },
        "installSystemDeps": {
            "type": "boolean",
            "default": true,
            "description": "Install the browser system dependencies."
        },
        "minReleaseAge": {
            "type": "string",
            "default": "7",
            "description": "Minimum release age in days for npm installation."
        }
    }
}
