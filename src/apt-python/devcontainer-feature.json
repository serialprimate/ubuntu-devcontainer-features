{
    "name": "APT Python",
    "id": "apt-python",
    "version": "0.1.0-dev",
    "description": "Install Python and optional pip, pipx, and venv apt packages.",
    "options": {
        "version": {
            "type": "string",
            "enum": [
                "3.14"
            ],
            "default": "3.14",
            "description": "Python version to install."
        },
        "installPip": {
            "type": "boolean",
            "default": true,
            "description": "Install pip."
        },
        "installPipx": {
            "type": "boolean",
            "default": true,
            "description": "Install pipx. Requires venv to be installed."
        },
        "installVenv": {
            "type": "boolean",
            "default": true,
            "description": "Install venv."
        }
    }
}
